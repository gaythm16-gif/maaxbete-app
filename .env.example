# ===========================================
# BACKEND (Render) — ne pas committer .env
# ===========================================
# Port (Render définit PORT automatiquement)
PORT=
PROXY_PORT=3001

# Base de données MySQL (Railway fournit ces valeurs)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Frontend autorisé pour CORS (URL Vercel en production)
FRONTEND_URL=

# API Casino Nexus
CASINO_API_URL=https://api.nexusggr.com
CASINO_AGENT_CODE=
CASINO_TOKEN=
CASINO_SECRET=
# URL du site (frontend) pour l’API casino — en prod mettre l’URL Vercel
CASINO_SITE_ENDPOINT=
# Callback optionnel (URL publique du backend si l’API l’exige)
CASINO_CALLBACK_URL=
CASINO_GAME_LIST_PATH=/game/list

# Optionnel : mot de passe initial du compte master (premier démarrage MySQL)
# MASTER_INITIAL_PASSWORD=

# ===========================================
# FRONTEND (Vercel) — variable à définir dans Vercel
# ===========================================
# En production : URL du backend Render (ex. https://maaxbete-backend.onrender.com)
# En dev : laisser vide (le proxy Vite redirige /api vers le backend local)
# VITE_API_URL=
